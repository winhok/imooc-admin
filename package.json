{
  "name": "imooc-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "commit": "cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.18.1",
    "element-plus": "^2.14.2",
    "md5": "^2.3.0",
    "path-browserify": "^1.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/md5": "^2.3.6",
    "@types/node": "^26.0.1",
    "@types/path-browserify": "^1.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "4.3.2",
    "cz-customizable": "7.5.4",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.71.0",
    "eslint-plugin-vue": "~10.9.2",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.71.0",
    "postcss-html": "^1.8.1",
    "prettier": "3.9.1",
    "process": "^0.11.10",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^26.3.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  },
  "lint-staged": {
    "*.{vue,ts,mts,tsx}": [
      "oxlint --fix",
      "eslint --fix --cache",
      "prettier --write --experimental-cli"
    ],
    "*.{js,cjs,mjs,jsx,json,jsonc,css,scss,less,md,yml,yaml,html}": [
      "prettier --write --experimental-cli"
    ]
  },
  "description": "This template should help get you started developing with Vue 3 in Vite.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winhok/imooc-admin.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/winhok/imooc-admin/issues"
  },
  "homepage": "https://github.com/winhok/imooc-admin#readme"
}
