{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue"],
  "env": {
    "browser": true,
    "vue": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-undef": "error"
  },
  "overrides": [
    {
      "files": ["**/*.cjs", "**/*.config.{js,ts,mjs,cjs}"],
      "env": {
        "node": true
      }
    }
  ]
}
